<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.ConfirmDialog"
        Title="Confirm"
        Width="440"
        Height="220"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        Topmost="True"
        ShowInTaskbar="False">

    <Panel Margin="20" Name="RootPanel" Opacity="0">
        <!-- Window Shadow -->
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 8 32 0 #80000000"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1">
            
            <Grid Name="MainGrid" RowDefinitions="Auto, *, Auto">
                
                <!-- Custom Title Bar (Draggable) -->
                <Border Grid.Row="0"
                        Name="TitleBar"
                        Background="{StaticResource BrBgDeep}"
                        Height="45"
                        CornerRadius="12,12,0,0"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Name="TxtIcon"
                                       Text="&#xE9CE;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                       Foreground="{StaticResource BrAccent}"
                                       FontSize="18"
                                       Margin="0,0,12,0"/>
                            <TextBlock Name="TxtTitle"
                                       Text="Confirmation"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrTextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Close button -->
                        <Button Grid.Column="1"
                                Name="BtnCloseTop"
                                Classes="BtnBase"
                                Width="45" Height="45"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="0,12,0,0"
                                Click="BtnCancel_Click">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                       FontSize="12"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <TextBlock Name="TxtMessage"
                           Grid.Row="1"
                           Text="Are you sure?"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="24,20"
                           Foreground="{StaticResource BrTextSecondary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <!-- Action Buttons -->
                <Border Grid.Row="2"
                        Padding="20,16"
                        Background="{StaticResource BrBgDeep}"
                        CornerRadius="0,0,12,12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Name="BtnCancel"
                                Content="Cancel"
                                Classes="BtnBase"
                                MinWidth="90"
                                Click="BtnCancel_Click"/>
                        <Button Name="BtnConfirm"
                                Content="Confirm"
                                Classes="BtnPrimary"
                                MinWidth="110"
                                Click="BtnConfirm_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>
