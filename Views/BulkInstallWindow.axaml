<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptiscalerClient"
        xmlns:converters="clr-namespace:OptiscalerClient.Converters"
        xmlns:models="clr-namespace:OptiscalerClient.Models"
        mc:Ignorable="d"
        x:Class="OptiscalerClient.Views.BulkInstallWindow"
        Title="{DynamicResource TxtBulkInstallWindow}"
        Height="700" Width="900"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>

    <Panel Margin="15" Name="RootPanel" Opacity="0">
        <!-- Main Container with Shadow -->
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 8 32 0 #80000000"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header -->
                    <RowDefinition Height="Auto"/>   <!-- Select All -->
                    <RowDefinition Height="*"/>      <!-- Games List -->
                    <RowDefinition Height="Auto"/>   <!-- Settings -->
                    <RowDefinition Height="Auto"/>   <!-- Progress -->
                    <RowDefinition Height="Auto"/>   <!-- Action bar -->
                </Grid.RowDefinitions>

                <!-- ════════════════════════════════════════════════════════
                     HEADER / TITLE BAR
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="0"
                        Name="TitleBar"
                        Background="{StaticResource BrBgDeep}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource TxtBulkInstallWindow}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Name="BtnClose"
                                Content="✕"
                                Classes="BtnBase"
                                Padding="10,5"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     SELECT ALL SECTION
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="1"
                        Background="{StaticResource BrBgSurface}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Name="ChkSelectAll"
                                  Content="{DynamicResource TxtSelectAll}"
                                  FontWeight="Medium"
                                  Foreground="{StaticResource BrTextPrimary}"
                                  FontSize="12"
                                  Click="ChkSelectAll_Click"/>

                        <TextBlock Grid.Column="1"
                                   Name="TxtSelectionCount"
                                   Text="0 games selected"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     GAMES LIST (Scrollable)
                     ════════════════════════════════════════════════════════ -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0">
                    <ItemsControl Name="GamesList" Padding="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrBgSurface}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        Margin="12,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanInstall}"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"/>

                                        <Image Grid.Column="1"
                                               Source="{Binding CoverPath}"
                                               Width="28"
                                               Height="42"
                                               Stretch="UniformToFill"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,28,42" RadiusX="3" RadiusY="3"/>
                                            </Image.Clip>
                                        </Image>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrTextPrimary}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding Platform}"
                                                       Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="10"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                            <!-- OptiScaler badge (violet) -->
                                            <Border Background="#1E1530"
                                                    BorderBrush="{StaticResource BrAccent}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="6,2"
                                                    IsVisible="{Binding IsOptiscalerInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✦ OptiScaler"
                                                               Foreground="{StaticResource BrAccent}"
                                                               FontSize="8"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding OptiscalerVersion, StringFormat=' {0}'}"
                                                               Foreground="{StaticResource BrAccent}"
                                                               FontSize="8"
                                                               FontWeight="SemiBold"
                                                               IsVisible="{Binding OptiscalerVersion, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Installed badge -->
                                            <Border Background="{StaticResource BrBgDeep}"
                                                    CornerRadius="3"
                                                    Padding="6,2"
                                                    IsVisible="{Binding IsInstalled}">
                                                <TextBlock Text="{DynamicResource TxtInstalled}"
                                                           FontSize="9"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource BrTextSecondary}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ════════════════════════════════════════════════════════
                     INSTALLATION SETTINGS
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="3"
                        Background="{StaticResource BrBgSurface}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,1,0,1"
                        Padding="24,20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{DynamicResource TxtInstallationSettings}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="{DynamicResource TxtVersion}"
                                           FontSize="13"
                                           Foreground="{StaticResource BrTextSecondary}"/>
                                <ComboBox Name="CmbOptiVersion"
                                          HorizontalAlignment="Stretch"
                                          Background="{StaticResource BrBgBase}"
                                          Foreground="{StaticResource BrTextPrimary}"
                                          BorderBrush="{StaticResource BrBorderSubtle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="12" VerticalAlignment="Center">
                                <CheckBox Name="ChkFakenvapi"
                                          Content="{DynamicResource TxtInstallFakenvapi}"
                                          Foreground="{StaticResource BrTextPrimary}"/>
                                <CheckBox Name="ChkNukemFG"
                                          Content="{DynamicResource TxtInstallNukemFG}"
                                          Foreground="{StaticResource BrTextPrimary}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     PROGRESS BAR
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="4"
                        Name="ProgressSection"
                        Background="{StaticResource BrBgDeep}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1"
                        Padding="24,16"
                        IsVisible="False">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Name="TxtProgressStatus"
                                       Text="Installing..."
                                       FontSize="13"
                                       Foreground="{StaticResource BrTextPrimary}"/>
                            <TextBlock Name="TxtProgressCount"
                                       Text="1 / 5"
                                       FontSize="13"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                        <ProgressBar Name="ProgressBar"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Background="{StaticResource BrBgBase}"
                                     Foreground="{StaticResource BrAccent}"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     ACTION BAR
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="5"
                        Background="{StaticResource BrBgDeep}"
                        CornerRadius="0,0,12,12"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Name="BtnCancel"
                                Content="{DynamicResource TxtCancel}"
                                Classes="BtnBase"
                                Padding="12,6"
                                HorizontalAlignment="Left"
                                Click="BtnCancel_Click"/>

                        <Button Grid.Column="1"
                                Name="BtnInstall"
                                Content="{DynamicResource TxtInstallSelected}"
                                Classes="BtnBase BtnPrimary"
                                Padding="16,6"
                                Click="BtnInstall_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>
